# =========================================================================
# KrishiMitra AI - Backend Environment Template Configuration
# =========================================================================

# Server setup configuration
PORT=5000
NODE_ENV=development

# JSON Web Token keys
JWT_SECRET=your_jwt_signing_token_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Database: MongoDB Atlas cloud connection URI
# Replace <username> and <password> with your Atlas database user credentials.
# CRITICAL: If your password contains special characters (like @ or #), you MUST URL-encode them.
# Example: '@' becomes '%40', '#' becomes '%23' (e.g. 'Pass@123' becomes 'Pass%40123').
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/krishimitra?retryWrites=true&w=majority

# Gemini Generative AI API Client credentials
# Leave empty to trigger translated JSON local mock databases
GEMINI_API_KEY=your_gemini_generative_ai_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# Meteorological: OpenWeather API Key
# Leave empty to trigger deterministic coordinate weather mock advisory simulators
OPENWEATHER_API_KEY=your_openweather_api_token_here

# Storage: Cloudinary cloud account credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
